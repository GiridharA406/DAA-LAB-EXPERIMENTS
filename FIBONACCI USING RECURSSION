#include <stdio.h>

long long fibonacciRecursive(int n) {
    if (n <= 1) {
        return n;
    }
    return fibonacciRecursive(n - 1) + fibonacciRecursive(n - 2);
}

int main() {
    int n;
    printf("Enter the value of n: ");
    scanf("%d", &n);
    printf("Recursive: Fibonacci term %d is %lld\n", n, fibonacciRecursive(n));
    return 0;
}
