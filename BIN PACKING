#include <stdio.h>

int firstFit(int weight[], int n, int capacity) {
    int res = 0;
    int bin_rem[n];
    for (int i = 0; i < n; i++) {
        int j;
        for (j = 0; j < res; j++) {
            if (bin_rem[j] >= weight[i]) {
                bin_rem[j] = bin_rem[j] - weight[i];
                break;
            }
        }
        if (j == res) {
            bin_rem[res] = capacity - weight[i];
            res++;
        }
    }
    return res;
}

int main() {
    int weight[] = {2, 5, 4, 7, 1, 3, 8};
    int capacity = 10;
    int n = sizeof(weight) / sizeof(weight[0]);
    
    printf("Number of bins required: %d\n", firstFit(weight, n, capacity));
    
    return 0;
}
